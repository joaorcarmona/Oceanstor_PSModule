# PowerShell source and test files — normalize to CRLF
*.ps1     text eol=crlf
*.psm1    text eol=crlf
*.psd1    text eol=crlf
*.ps1xml  text eol=crlf

# Common text files — normalize to LF (cross-platform default)
*.md      text eol=lf
*.yml     text eol=lf
*.yaml    text eol=lf
*.json    text eol=lf
*.xml     text eol=lf
*.txt     text eol=lf
